---
// Markup shell for the /networks company-landscape map. All behavior lives in
// ../scripts/networks-graph.ts (a default processed <script> so its bundled
// d3 + data imports work).
//
// The PRIVATE overlay (warm paths + pipeline stage) is read here from
// private/overlay.json — but ONLY under `import.meta.env.DEV`. A production
// build (the only thing deployed) dead-eliminates the read, so warm paths and
// pipeline data are never shipped to the public site. The file is also
// gitignored. See the privacy invariant in the plan / experiments/networks.

let overlayEntries: unknown[] = [];
if (import.meta.env.DEV) {
  try {
    const { readFileSync, existsSync } = await import("node:fs");
    if (existsSync("private/overlay.json")) {
      const raw = JSON.parse(readFileSync("private/overlay.json", "utf8"));
      overlayEntries = Array.isArray(raw) ? raw : (raw.entries ?? []);
    }
  } catch {
    /* overlay is optional — absence just means public (landscape-only) view */
  }
}
const isPrivate = overlayEntries.length > 0;
// guard against </script> breaking out of the JSON island
const overlayJson = JSON.stringify(overlayEntries).replace(/</g, "\\u003c");
---

<figure class="net-figure">
  <div class="net-controls">
    <input
      id="net-search"
      type="search"
      placeholder="search companies…"
      autocomplete="off"
      spellcheck="false"
    />
    <div id="net-verticals" class="net-chips" aria-label="filter by vertical"></div>
    {isPrivate && <div id="net-stages" class="net-chips net-chips-priv" aria-label="filter by pipeline stage"></div>}
    <button
      id="net-download"
      class="net-chip net-action"
      type="button"
      aria-label="download the current view as a PNG image"
      title="download the current view as a PNG image"
    >
      <span class="ic" aria-hidden="true">↓</span> download
    </button>
  </div>

  <div class="net-stage">
    <div id="net-graph">
      <noscript><p class="graph-noscript">The map needs JavaScript — the landscape is interactive.</p></noscript>
    </div>
    <div id="net-detail"></div>
  </div>

  <figcaption id="net-legend"></figcaption>
</figure>
<div id="net-tip" class="gtooltip" aria-hidden="true"></div>

<script type="application/json" id="net-overlay" is:inline set:html={overlayJson}></script>
<script>
  import { initNetworkGraph } from "../scripts/networks-graph";
  let entries = [];
  try {
    const el = document.getElementById("net-overlay");
    entries = el ? JSON.parse(el.textContent || "[]") : [];
  } catch {
    entries = [];
  }
  initNetworkGraph(entries);
</script>

<style is:global>
  /* ── /networks map chrome ───────────────────────────────────────────
     Runtime-created SVG + injected panels never get Astro's scoped hash,
     so these MUST be global. Distinct #net-* ids keep it fully decoupled
     from the /team graph (#graph/#detail). Palette mirrors VERTICALS /
     STAGES in src/data/network-types.ts. */
  /* /networks is a full-page map: the figure fills the viewport below the nav,
     full-bleed (escaping the centered 1140px body), no footer (see Base.astro). */
  body.full-page { overflow-x: hidden; }
  .net-figure {
    margin: 0;
    border: none;
    padding: 0.6rem 0 0;
    /* fill the viewport below the masthead (body top-padding 2rem + masthead ~2.1rem) */
    height: calc(100vh - 4.25rem);
    display: flex;
    flex-direction: column;
    /* full-bleed width */
    width: 100vw;
    position: relative;
    left: 50%;
    margin-left: -50vw;
  }

  .net-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.7rem;
    padding: 0 1.5rem 0.6rem;
  }
  #net-search {
    font-family: var(--font);
    font-size: 0.82rem;
    color: var(--fg);
    background: #fff;
    border: 1px solid var(--rule-soft);
    border-radius: 4px;
    padding: 5px 9px;
    outline: none;
    min-width: 180px;
  }
  #net-search:focus { border-color: var(--muted-2); }

  .net-chips { display: flex; flex-wrap: wrap; gap: 5px; }
  .net-chips-priv { width: 100%; padding-top: 2px; }
  .net-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--muted-2);
    background: #fff;
    border: 1px solid var(--rule-soft);
    border-radius: 999px;
    padding: 2px 9px;
    cursor: pointer;
    transition: color 0.12s, border-color 0.12s, opacity 0.12s;
    opacity: 0.5;
  }
  .net-chip .sw { width: 9px; height: 9px; border-radius: 50%; flex: none; }
  .net-chip:hover { color: var(--fg); }
  .net-chip.on { opacity: 1; color: var(--fg); border-color: var(--muted-2); }
  .net-chip-warm.on { color: var(--accent); border-color: var(--accent); }
  /* "hide all / show all" action — always reads as active, distinct from categories */
  .net-chip-toggle {
    opacity: 1; color: var(--fg); border-color: var(--muted-2);
    font-variant: small-caps; letter-spacing: 0.06em; margin-right: 0.2rem;
  }
  .net-chip-toggle:hover { background: var(--accent-soft); border-color: var(--accent); color: var(--accent); }
  /* "download" — a quiet utility action, pushed to the right edge of the controls row */
  .net-action {
    opacity: 1; color: var(--muted-2); border-color: var(--rule-soft);
    margin-left: auto; font-variant: small-caps; letter-spacing: 0.06em;
  }
  .net-action:hover { background: var(--accent-soft); border-color: var(--accent); color: var(--accent); }
  .net-action .ic { font-variant: normal; }

  .net-stage { position: relative; flex: 1 1 auto; min-height: 0; }
  #net-graph {
    height: 100%;
    cursor: grab;
    overflow: hidden;
  }
  #net-graph:active { cursor: grabbing; }
  #net-graph svg { display: block; width: 100%; height: 100%; touch-action: pan-y; }
  /* .graph-noscript (centered offline note) is defined in global.css — reused here */
  .net-label {
    font-size: 11px; fill: var(--fg); text-anchor: middle; pointer-events: none;
    paint-order: stroke; stroke: var(--bg); stroke-width: 3px; stroke-linejoin: round;
  }

  /* dossier panel — floats top-right in the frame, drops below on phones */
  #net-detail {
    position: absolute; top: 12px; right: 12px; z-index: 5;
    width: 300px; max-width: calc(100% - 24px); max-height: calc(100% - 24px);
    overflow-y: auto;
    background: var(--bg); border: 1px solid var(--rule-soft); border-radius: 3px;
    padding: 11px 13px; font-size: 0.78rem; line-height: 1.45; color: var(--fg);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }
  #net-detail:empty { display: none; }
  #net-detail .d-clear { float: right; color: var(--muted-2); cursor: pointer; margin-left: 8px; }
  #net-detail .d-clear:hover { color: var(--fg); }
  #net-detail .d-title { font-weight: 700; font-size: 0.92rem; line-height: 1.2; }
  #net-detail .d-sub { font-size: 0.72rem; margin: 1px 0 7px; }
  #net-detail .d-int { letter-spacing: 1px; font-size: 0.66rem; }
  #net-detail .d-blurb { color: var(--fg); margin-bottom: 7px; }
  #net-detail .d-line { color: var(--muted); margin: 0 0 4px; }
  #net-detail .d-key {
    font-variant: small-caps; letter-spacing: 0.08em; font-size: 0.68rem;
    color: var(--muted-2); margin-right: 0.3rem;
  }
  #net-detail .d-rels { margin-top: 7px; border-top: 1px solid var(--rule-soft); padding-top: 6px; }
  #net-detail .d-row { display: flex; gap: 7px; margin: 0 0 5px; }
  #net-detail .swatch { width: 9px; height: 9px; border-radius: 50%; flex: none; margin-top: 4px; }
  #net-detail .d-org { font-weight: 600; }
  #net-detail .d-meta { color: var(--muted-2); font-size: 0.72rem; }
  #net-detail .d-src { margin-top: 6px; }
  #net-detail .d-src a { color: var(--accent-press); font-size: 0.72rem; text-decoration: underline; }
  /* private block */
  #net-detail .d-priv {
    margin: 7px 0; padding: 7px 9px; border-radius: 3px;
    background: var(--accent-soft); border: 1px solid #f0d9d9;
  }
  #net-detail .d-badge {
    display: inline-block; color: #fff; font-size: 0.66rem; padding: 1px 7px;
    border-radius: 999px; font-variant: small-caps; letter-spacing: 0.06em;
  }
  #net-detail .d-warm { margin-top: 5px; line-height: 1.4; }
  #net-detail .d-note { margin-top: 5px; font-style: italic; color: var(--muted); }

  /* legend (size + provenance keys) */
  #net-legend {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem 1.2rem;
    flex: none; padding: 0.45rem 1.5rem;
    font-size: 0.72rem; color: var(--muted);
  }
  .net-leg-item { display: inline-flex; align-items: center; gap: 6px; }
  .net-leg-dot { background: var(--muted); border-radius: 50%; display: inline-block; }
  .net-leg-ln { width: 18px; height: 0; border-top: 1.6px solid #9a958c; display: inline-block; }
  .net-leg-ln.dash { border-top-style: dashed; }
  .net-leg-priv { color: var(--accent); }
  .net-leg-dim { color: var(--muted-2); font-style: italic; margin-left: auto; }

  /* tooltip (reuses .gtooltip base from global.css, incl. .t-name) */
  #net-tip .t-badge, #net-detail .d-badge { vertical-align: middle; }
  #net-tip .t-badge {
    display: inline-block; color: #fff; font-size: 0.62rem; padding: 0 6px;
    border-radius: 999px; font-variant: small-caps; margin-left: 4px;
  }
  #net-tip .t-sub { font-size: 0.72rem; margin: 1px 0 4px; }
  #net-tip .t-blurb { color: var(--fg); font-size: 0.74rem; }
  #net-tip .t-warm { color: var(--accent); font-size: 0.72rem; margin-top: 4px; }

  @media (max-width: 640px) {
    #net-detail {
      position: static; width: auto; max-width: none; max-height: none;
      margin-top: 0.6rem; box-shadow: none;
    }
  }
</style>
