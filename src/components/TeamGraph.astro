---
// Markup shell for the evidence network. All behavior lives in
// ../scripts/team-graph.ts, which also wires the TeamGrid cards below it.
// The <script> tag must stay a default processed tag (no is:inline /
// define:vars) or its bundled imports silently break.
// Legend colors mirror the TYPE dict in team-graph.ts — keep in sync.
---

<figure class="team-figure">
  <div id="graph">
    <noscript><p class="graph-noscript">The map needs JavaScript — the people are below.</p></noscript>
  </div>
  <div id="detail"></div>
  <figcaption>
    <span class="legend" aria-hidden="true">
      <span style="color:#a00">us &amp; our joint work</span> ·
      <span style="color:#7a5230">labs</span> ·
      <span style="color:#8a8475">universities</span> ·
      <span style="color:#50796f">communities</span> ·
      <span style="color:#6b5a7e">companies</span>
    </span>
    <span class="fignote">hand-curated — click anyone; every claim links to its source</span>
  </figcaption>
</figure>
<div id="tooltip" class="gtooltip" aria-hidden="true"></div>

<script>
  import { initTeamGraph } from "../scripts/team-graph";
  initTeamGraph();
</script>
