---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Agents of Chaos — Red-teaming for multi-agent AI systems",
  description = "Agents of Chaos runs live multi-agent red-team campaigns against frontier AI agents. We authored the Agents of Chaos study and have led internal red-team engagements for a frontier lab.",
} = Astro.props;

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
// /networks is a full-page map: it fills the viewport below the nav, no footer.
const isNetworks = path === "/networks" || path === "/networks/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/brand/aoc-mark.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.png" type="image/png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body class={isNetworks ? "full-page" : undefined}>
    <header class="masthead">
      <a class="wordmark" href="/" aria-label="Agents of Chaos home">
        <img class="wordmark-logo" src="/brand/aoc-logo-aoc.svg" alt="" />
        <span class="sr-only">Agents of Chaos</span>
      </a>
      <nav>
        <a href="/team" aria-current={isCurrent("/team") ? "page" : undefined}>team</a>
        <a href="/papers" aria-current={isCurrent("/papers") ? "page" : undefined}>papers</a>
        <a href="/networks" aria-current={isCurrent("/networks") ? "page" : undefined}>networks</a>
        <a href="/contact" aria-current={isCurrent("/contact") ? "page" : undefined}>contact</a>
      </nav>
    </header>

    <slot />

    {!isNetworks && <Footer />}
  </body>
</html>
