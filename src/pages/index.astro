---
import Base from "../layouts/Base.astro";
import LoopDiagram from "../components/LoopDiagram.astro";
---

<Base>
  <header class="hero">
    <div class="hero-ambient" aria-hidden="true"></div>
    <div class="hero-copy">
      <p class="kicker">multi-agent red-team infrastructure</p>
      <h1 class="sr-only">Agents of Chaos</h1>
      <img
        class="hero-title-logo"
        src="/brand/aoc-logo-agents-of-chaos.svg"
        alt=""
        aria-hidden="true"
      />
      <p class="subtitle">Built to operate. Designed to disrupt.</p>
      <p class="hero-summary">
        We build realistic agent environments, attack them under pressure, and
        turn the failures into deployment-grade safety plans.
      </p>
      <div class="hero-meta" aria-label="Core services">
        <span>agent environments</span>
        <span>adversarial campaigns</span>
        <span>deployment reports</span>
      </div>
      <nav class="hero-nav">
        <a href="#track-record">track record</a>
        <a href="#what-we-do">what we do</a>
        <a href="/contact">contact</a>
      </nav>
    </div>
  </header>

  <section class="signal-board" aria-label="Agents of Chaos capabilities">
    <div>
      <span class="board-num">01</span>
      <h2>Model the environment</h2>
      <p>Reproduce the tools, roles, messages, policies, and incentives your agents will face in production.</p>
    </div>
    <div>
      <span class="board-num">02</span>
      <h2>Run adversarial campaigns</h2>
      <p>Pressure-test agent populations until they leak data, spoof authority, collude, or report false success.</p>
    </div>
    <div>
      <span class="board-num">03</span>
      <h2>Deliver operational fixes</h2>
      <p>Translate failures into evidence, mitigations, and safety checks that engineering teams can act on.</p>
    </div>
  </section>

  <div class="reading">
    <span class="section-label"><span class="num">01</span>/ intro</span>

    <p class="intro">
      <span class="drop">M</span><b
        >ulti-agent AI systems are the next major unlock.</b
      >&nbsp;Banks will soon use agents for customer service, healthcare will use
      them for triage, and coding agents are already interacting with each other.
    </p>

    <p class="intro">
      These agents are <span class="cite-pop" data-cite-pop
        ><button
          type="button"
          class="cite-trigger"
          aria-haspopup="dialog"
          aria-expanded="false">not yet safe</button
        ><span
          class="cite-panel"
          role="dialog"
          aria-label="Evidence that multi-agent systems are not yet safe"
          hidden
          ><a
            class="cite-item"
            href="https://agentsofchaos.baulab.info/"
            target="_blank"
            rel="noopener"
            ><span class="cite-head"
              >Agents of Chaos: red-teaming multi-agent AI systems</span
            ><span class="cite-desc"
              >Shapira et al. Northeastern University</span
            ></a
          ><a
            class="cite-item"
            href="https://www.bbc.com/news/articles/c98rzr72dpyo"
            target="_blank"
            rel="noopener"
            ><span class="cite-head"
              >Instagram AI chatbot tricked by hackers to give access to others'
              accounts</span
            ><span class="cite-desc"
              >Reported by Liv McMahon for BBC News</span
            ></a
          ></span
        ></span
      >&nbsp;when put in multi-agent environments, creating a massive safety
      bottleneck in real deployment.
    </p>

    <p class="intro closer">
      We fix this bottleneck.
    </p>
  </div>

  <script>
    document.querySelectorAll<HTMLElement>("[data-cite-pop]").forEach((pop) => {
      const trigger = pop.querySelector<HTMLButtonElement>(".cite-trigger");
      const panel = pop.querySelector<HTMLElement>(".cite-panel");
      if (!trigger || !panel) return;

      let closeTimer = 0;
      const close = () => {
        panel.hidden = true;
        trigger.setAttribute("aria-expanded", "false");
      };
      const cancelClose = () => window.clearTimeout(closeTimer);
      const scheduleClose = () => {
        cancelClose();
        closeTimer = window.setTimeout(close, 260);
      };

      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        cancelClose();
        const opening = panel.hidden;
        panel.hidden = !opening;
        trigger.setAttribute("aria-expanded", String(opening));
      });
      panel.addEventListener("click", (e) => e.stopPropagation());
      pop.addEventListener("mouseenter", cancelClose);
      pop.addEventListener("mouseleave", scheduleClose);
      document.addEventListener("click", close);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") close();
      });
    });

  </script>

  <LoopDiagram />

  <div class="reading">
    <p class="lede">
      <span class="drop">W</span>e custom-build the test environment that your
      agents will run in. We use that environment to build and red-team groups
      of AI agents, improving the system as failures appear. The process removes
      sources of potential harm, measures what changed, and leaves teams with
      agent deployments they can operate in high-pressure settings.
    </p>

    <span class="section-label" id="track-record"
      ><span class="num">02</span>/ background</span
    >
    <h2>Track record</h2>

    <p>
      <b>Since </b><a href="https://openclaw.ai/">OpenClaw</a><b> was introduced</b>, we have been stress-testing agentic systems.
      We were the first to publish work on red-teaming multiple agents, <em><b>Agents of Chaos</b></em>
      (<a href="https://agentsofchaos.baulab.info/">Shapira et al., 2026</a>),
      covered by <a href="https://www.science.org/content/article/ai-algorithms-can-become-agents-chaos"><i>Science</i></a> and <a href="https://www.wired.com/story/openclaw-ai-agent-manipulation-security-northeastern-study/"><i>Wired</i></a>. The work documented how autonomous
      agents leak private data, spoof identity, and report false success.
      We were later hired by a frontier lab to design and lead an internal
      red-teaming campaign, producing measurable improvements and a follow-up
      engagement.
    </p>

    <span class="section-label" id="what-we-do"
      ><span class="num">03</span>/ approach</span
    >
    <h2>What we do</h2>
    <div class="what-list">
      <p>
        <strong>Custom agentic infrastructure.</strong>&nbsp;We adapt your
        business's native environment and workflow into a realistic operating
        environment for agents to work in, and for us to stress-test.
      </p>
      <p>
        <strong>Red-teaming campaigns.</strong>&nbsp;We research your
        agent-integrated workflow, then attack it to uncover agentic
        vulnerabilities before they cause real harm.
      </p>
      <p>
        <strong>Integrated harm reports.</strong>&nbsp;We deliver a structured
        plan for safe integration, with harm taxonomies, severity ratings,
        sanitised artifacts, and recommended mitigations your team can act on
        immediately.
      </p>
    </div>
  </div>
</Base>
