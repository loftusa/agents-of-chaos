---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Base
  title="Blog — Agents of Chaos"
  description="Notes on multi-agent red-teaming, emergent harm, and adversarial infrastructure."
>
  <div class="reading">
    <div class="page-head">
      <h1>Blog</h1>
      <p class="subtitle">Notes on multi-agent red-teaming.</p>
    </div>

    {
      posts.length === 0 ? (
        <p class="mu">No posts yet.</p>
      ) : (
        <ul class="post-list">
          {posts.map((p) => (
            <li>
              <span class="post-date">{fmt(p.data.date)}</span>
              <a href={`/blog/${p.id}`}>{p.data.title}</a>
              {p.data.description && <p class="post-desc">{p.data.description}</p>}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</Base>
