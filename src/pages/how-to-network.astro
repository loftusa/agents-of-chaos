    background: var(--correct-soft);
  }
  .htn-drill.answered .htn-opt.is-correct .htn-opt-text::before {
    content: "✓ ";
    color: var(--correct);
  }
  .htn-drill.answered .htn-opt.chosen.is-wrong {
    opacity: 1;
    border-color: var(--muted-2);
  }
  .htn-drill.answered .htn-opt.chosen.is-wrong .htn-opt-text::before {
