    color: var(--muted);
    line-height: 1.45;
  }
  .htn-drill.answered .htn-opt.is-correct .htn-why,
  .htn-drill.answered .htn-opt.chosen .htn-why {
    display: block;
  }
  .htn-drill-result {
    margin: 0.8rem 0 0;
    min-height: 1rem;
    font-size: 0.82rem;
    font-variant: small-caps;
    letter-spacing: 0.1em;
    color: var(--muted-2);
  }
  .htn-drill.answered.got-it .htn-drill-result {
    color: var(--correct);
  }
  .htn-drill.answered.missed .htn-drill-result {
    color: var(--accent);
  }

  /* ── capstone + close ──────────────────────────────────────────── */
  .htn-capstone {
    margin-top: 5rem;
    scroll-margin-top: 2rem;
  }
  .htn-cap-h {
    margin-bottom: 0.8rem;
  }
  .htn-cap-scenario {
    font-style: italic;
    color: var(--fg);
    margin-bottom: 0.4rem;
  }
  .htn-close {
    margin-top: 4rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--rule);
    font-size: 1.05rem;
    color: var(--fg);
  }

  @media (max-width: 640px) {
    .htn-drill {
      padding: 0.9rem 0.9rem 1rem;
    }
  }
</style>

<script>
  // One-time lookup of rail links by their data-rail key, shared below.
  const railByKey = new Map<string, Element>();
  document
    .querySelectorAll<HTMLElement>(".htn-rail [data-rail]")
    .forEach((a) => railByKey.set(a.dataset.rail!, a));

  // Mark a section's rail dot "done" once all of its drills are answered.
  function markSectionDone(section: HTMLElement) {
    const done = Array.from(section.querySelectorAll(".htn-drill")).every((d) =>
      d.classList.contains("answered"),
    );
    if (done) railByKey.get(section.dataset.principle!)?.classList.add("is-done");
  }

  // ── Drill interaction: answer once, reveal all rationales, lock. ──
  document
    .querySelectorAll<HTMLElement>(".htn-drill[data-drill]")
    .forEach((drill) => {
      const opts = drill.querySelectorAll<HTMLButtonElement>(".htn-opt");
      const result = drill.querySelector<HTMLElement>(".htn-drill-result");
      const section = drill.closest<HTMLElement>("[data-principle]");
      opts.forEach((opt) => {
        opt.addEventListener("click", () => {
          if (drill.classList.contains("answered")) return;
          const isCorrect = opt.dataset.correct === "true";
          drill.classList.add("answered", isCorrect ? "got-it" : "missed");
          opt.classList.add("chosen");
          opts.forEach((o) => {
            o.setAttribute("disabled", "true");
            o.classList.add(
              o.dataset.correct === "true" ? "is-correct" : "is-wrong",
            );
          });
          if (result) {
            result.textContent = isCorrect
              ? "— right call"
              : "— not the strongest move — see why";
          }
          if (section) markSectionDone(section);
        });
      });
    });

  // ── Progress rail: highlight whichever section is currently in view. ──
  const sections = document.querySelectorAll<HTMLElement>("[data-principle]");
  if (sections.length && "IntersectionObserver" in window) {
    let activeLink: Element | null = null;
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const link = railByKey.get(
            (entry.target as HTMLElement).dataset.principle!,
          );
          if (link && link !== activeLink) {
            activeLink?.classList.remove("is-active");
            link.classList.add("is-active");
            activeLink = link;
          }
        }
      },
      { rootMargin: "-45% 0px -45% 0px" },
    );
    sections.forEach((s) => observer.observe(s));
  }
</script>
