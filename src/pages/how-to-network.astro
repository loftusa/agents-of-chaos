  }
  .htn-opts {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .htn-opt {
    text-align: left;
    font-family: var(--font);
    font-size: 0.95rem;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--rule);
    padding: 0.65rem 0.8rem;
